# Copiar este archivo a .env y ajustar segun el entorno.
# app/config.py define los defaults reales; este archivo documenta cada variable.

# --- App ---
APP_NAME=Image Upscaler AMD          # Nombre interno de la app (titulo del proceso FastAPI)
APP_HOST=127.0.0.1                   # Host de bind del servidor uvicorn
APP_PORT=8090                        # Puerto de bind del servidor uvicorn

# --- Limites de subida y validacion ---
MAX_UPLOAD_MB=50                     # Tamano maximo de subida para imagenes (MB)
MAX_VIDEO_UPLOAD_MB=2048             # Tamano maximo de subida para videos (MB)
MAX_IMAGE_PIXELS=120000000           # Limite de pixeles (ancho x alto) para evitar decompression bombs

# --- GPU, concurrencia y subprocesos ---
# Semaforos por dispositivo (app/services/device_semaphores.py): cada device_id
# (dml:0, dml:1, cpu...) tiene su propio semaforo, asi que jobs en GPUs fisicas
# distintas corren en paralelo en vez de serializar detras de un semaforo unico.
PER_DEVICE_GPU_CONCURRENCY=1         # Jobs simultaneos POR GPU (imagen+video comparten el semaforo de esa GPU); no subir sin perfilar VRAM
CPU_CONCURRENCY=2                    # Jobs simultaneos en CPU (modelos ONNX); no compite con la GPU
MAX_CONCURRENT_JOBS=4                # Workers por manager (imagen y video por separado); debe superar la cantidad de dispositivos que quieras correr en paralelo
SUBPROCESS_TIMEOUT=86400             # Backstop absoluto (24h) para cualquier subproceso; NO es el mecanismo real (ver watchdog abajo). Un episodio largo que avanza nunca debe morir por reloj.
FRAME_STALL_TIMEOUT_SECONDS=900      # Watchdog real: mata la etapa solo si NO produce frames/bytes nuevos por este tiempo (15 min). Se reinicia con cada frame nuevo, asi que un job lento pero progresando corre indefinidamente.

# --- FFmpeg (necesario solo para video) ---
FFMPEG_BINARY=vendor/ffmpeg/bin/ffmpeg.exe
FFPROBE_BINARY=vendor/ffmpeg/bin/ffprobe.exe
FFMPEG_DECODE_THREADS=12             # Hilos usados al extraer frames del video de entrada
FFMPEG_ENCODE_THREADS=24             # Hilos usados al re-encodear con libx264
FFMPEG_X265_THREADS=8                # Hilos usados al re-encodear con libx265 (limitado: libx265 falla en Windows con exceso de threads)
NCNN_UPSCALE_THREADS=2:24:12         # threads load:proc:save de Real-ESRGAN NCNN en video. proc alto = mejor uso de la GPU (medido 7800XT: 2:2:2->2.2fps, 2:24:12->5.3fps). GPU debil: bajarlo.

# --- Motor de upscaling (Real-ESRGAN NCNN Vulkan) ---
RUNTIME_DIR=runtime                  # Carpeta para uploads/outputs/temp/video-work (relativa a la raiz del proyecto)
ENGINE=realesrgan-ncnn               # Identificador del motor de upscaling activo
ENGINE_BINARY=vendor/realesrgan/realesrgan-ncnn-vulkan.exe
ENGINE_MODELS_DIR=vendor/realesrgan/models
DEFAULT_MODEL=realesrgan-x4plus      # Modelo preseleccionado en la web UI y en POST /api/v1/jobs
DEFAULT_SCALE=4                      # Escala preseleccionada
ALLOWED_SCALES=2,3,4                 # Escalas permitidas por la API (lista separada por comas)
DEFAULT_VIDEO_PROFILE=anime-balanced-2x  # Perfil de video preseleccionado en la web UI

# --- Retencion y limpieza automatica de runtime/outputs ---
OUTPUT_TTL_HOURS=24                  # Horas antes de borrar outputs y jobs terminados (el sweep corre cada hora)

# --- Seguridad y cola ---
# ALLOWED_ORIGINS: origenes permitidos para requests que cambian estado (POST/PUT/PATCH/DELETE).
# Si se deja sin definir, se deriva automaticamente de APP_HOST/APP_PORT
# (http://127.0.0.1:<APP_PORT> y http://localhost:<APP_PORT>, mas http://<APP_HOST>:<APP_PORT>
# si APP_HOST no es 127.0.0.1/0.0.0.0/localhost). Descomentar para fijarlo explicitamente.
# ALLOWED_ORIGINS=http://127.0.0.1:8090,http://localhost:8090
MAX_QUEUE_SIZE=20                    # Tamano maximo de cada cola de jobs (imagen y video por separado); responde 429 si se llena

# --- Interpolacion de fotogramas / FPS boost (RIFE NCNN Vulkan) ---
RIFE_BINARY=vendor/rife/rife-ncnn-vulkan.exe
RIFE_MODELS_DIR=vendor/rife/models
RIFE_MODEL=rife-v4.6                 # Modelo RIFE por defecto (recomendado, general-purpose)
ENABLE_INTERPOLATION=False           # Activa el FPS boost; requiere haber corrido scripts/download-rife.ps1
ALLOWED_FPS_MULTIPLIERS=2,3,4        # Multiplicadores de FPS permitidos por la API (lista separada por comas)

# --- Mejora de audio con IA (DeepFilterNet / RNNoise) ---
DEEPFILTER_BINARY=vendor/deepfilternet/deep-filter.exe
RNNOISE_MODEL=vendor/deepfilternet/models/sh.rnnn
ENABLE_AUDIO_ENHANCE=False           # Activa audio_enhance=deepfilter|rnnoise (denoise); requiere haber corrido scripts/download-deepfilternet.ps1

# --- Restauracion de audio (Apollo ONNX, EXPERIMENTAL) — apartado Audio + video ---
# Reconstruye banda perdida por compresion de codec (MP3/Opus/AAC de WhatsApp/redes).
# Motor ONNX multi-EP (corre en cualquier GPU DirectX12 o CPU, como los modelos de imagen).
ENABLE_AUDIO_RESTORE=False           # Activa restore=apollo; requiere el modelo (scripts/download-apollo.ps1)
APOLLO_RESTORE_MODEL=vendor/apollo/apollo.onnx  # Ruta al modelo Apollo exportado a ONNX (~74MB, vendored)
AUDIO_RESTORE_CHUNK_SECONDS=1.0      # Chunk del restore. Mantiene cada inferencia DirectML <2s (limite TDR de Windows; con 3.0s la GPU se resetea repetido). Si igual da "GPU timeout" en una GPU debil, usar device=cpu para el restore.
AUDIO_RESTORE_GPU_THROTTLE_SECONDS=0.15  # Pausa entre inferencias GPU para que el escritorio no se laguee tanto (solo dml:N). Para PC 100% fluido, correr el restore en CPU.
AUDIO_RESTORE_CPU_CHUNK_SECONDS=30.0  # En CPU (sin TDR) se usa este chunk grande: mas contexto y menos bordes = mejor calidad (menos borroso en pasajes fuertes). GPU usa el chunk chico de arriba.

# --- Super-resolucion de audio (AudioSR ONNX, EXPERIMENTAL) — 2o motor de restore ---
# Difusion latente 258M params (port propio: github.com/santiquiroz/port-audiosr-onnx).
# Cualquier banda -> 48kHz. Mucho mas pesado que Apollo (~2min de proceso por minuto
# de audio en GPU a 50 pasos) pero techo de calidad muy superior. Multi-EP (DML/CPU).
ENABLE_AUDIOSR=False                 # Activa restore=audiosr; requiere los modelos (scripts/download-audiosr-onnx.ps1, ~2.6GB)
AUDIOSR_MODEL_DIR=vendor/audiosr     # Carpeta con los 4 .onnx + manifest.json del port
AUDIOSR_DDIM_STEPS=50                # Pasos de difusion: 50 = calidad paper; 25 = mitad de tiempo con perdida leve
AUDIOSR_GPU_THROTTLE_SECONDS=0.01    # Respiro por paso DDIM para el compositor de Windows (solo dml:N)
# TDR: cada paso DDIM es UNA llamada al UNet sobre la ventana completa (no chunkeable sin
# romper el modelo). En la 7800 XT son ~90ms; una GPU ~20x mas lenta podria tocar el limite
# TDR de Windows (~2s). Si aparece "GPU timeout", usar device=cpu para audiosr.
MAX_AUDIO_UPLOAD_MB=200              # Tamano maximo de subida en el apartado Audio standalone (MB)

# --- Interpolacion de maxima calidad (GMFSS_Fortuna ONNX, EXPERIMENTAL) — 2o motor de FPS boost ---
# Softmax-splatting, GridNet fusion, afinado para anime (port propio:
# github.com/santiquiroz/port-gmfss-onnx). Motor opt-in por job (interp_engine=gmfss);
# el default de cada job SIEMPRE es RIFE, este motor nunca reemplaza ese default.
# Max quality, mucho mas lento -- 10x o mas lento que RIFE (medido aislado: 0.72-0.73fps
# @1080p 2x en una RX 7800 XT, solo alcanzable con DirectML + fusionnet fp16 + splat GPU
# OpenCL; en fp32/splat CPU baja a ~0.2fps). En jobs completos sobre clips cortos la razon
# medida sube a ~20x por el overhead de carga en frio de los 4 grafos ONNX -- no tomar ese
# numero como estable, solo como piso conservador en clips largos. Sin TDR relevante (a
# diferencia de AudioSR): los grafos GMFSS son chicos y cada llamada es corta, no hay
# chunking ni limite de Windows que tocar.
ENABLE_GMFSS=False                   # Activa interp_engine=gmfss; requiere los modelos (scripts/download-gmfss-onnx.ps1, ~55MB)
GMFSS_MODEL_DIR=vendor/gmfss         # Carpeta con los 4 .onnx + manifest.json del port (+ fusionnet_fp16.onnx opcional)

# --- Aviso de actualizaciones (app/services/update_service.py, GET /api/v1/update-check) ---
# Chequeo silencioso y a prueba de fallos de una release mas nueva en GitHub.
# Reutilizable en otro proyecto: cambiar UPDATE_REPO + UPDATE_PACKAGE_NAME (sin tocar codigo).
UPDATE_REPO=santiquiroz/upflow       # owner/nombre del repo cuyas releases se revisan
UPDATE_PACKAGE_NAME=upflow           # paquete instalado cuya version se compara con el tag; tambien define el User-Agent
UPDATE_CHECK_ENABLED=True            # apaga el chequeo por completo si es False
UPDATE_CHECK_TTL_SECONDS=3600        # cache en memoria de un resultado bueno (evita el rate-limit anonimo de GitHub, 60/h)
UPDATE_ERROR_RETRY_SECONDS=300       # un error sin resultado bueno previo se cachea solo esto (reintenta pronto)
UPDATE_API_TIMEOUT_SECONDS=5.0       # timeout del request a la API de GitHub

# --- Seleccion de dispositivo (motor ONNX/DirectML, GET /api/v1/devices) ---
DEFAULT_DEVICE=dml:0                 # id preferido (cpu|dml:N); si no hay GPU DirectML disponible, cae automaticamente a cpu
# cpu es invalido para los modelos builtin NCNN (requieren GPU Vulkan); solo sirve para modelos ONNX instalados desde HF

# --- Auto-router opcional entre dispositivos (app/services/device_router.py) ---
# Con ENABLE_AUTO_ROUTE=True, los jobs sin dispositivo fijo (o con device="auto") se
# reparten al PRIMER dispositivo COMPATIBLE libre en vez de encolarse en uno solo:
# builtin NCNN -> solo GPUs Vulkan (nunca cpu); ONNX -> cpu o cualquier GPU.
# Util para reescalar una temporada completa: los episodios encolados se reparten
# entre las GPUs libres. Default False (respeta el dispositivo elegido por cada job).
ENABLE_AUTO_ROUTE=False

# --- Modelos ONNX instalados desde Hugging Face (GET/POST /api/v1/models*) ---
MODELS_DIR=models                    # Carpeta donde se guardan los .onnx instalados desde HF (relativa a la raiz del proyecto)
# HF_TOKEN=hf_xxx                    # Token opcional de Hugging Face (repos privados / evitar rate limiting anonimo); vacio por defecto
MAX_MODEL_DOWNLOAD_MB=2048           # Tamano maximo permitido para un archivo de modelo descargado desde HF (MB)
ONNX_TILE_SIZE=256                   # Tamano de tile (px) para inferencia ONNX por partes, con blend de 16px de solape; 0 desactiva el tiling

# --- Backend de upscale de video: selector de Runtime (SP11) ---
# Motor que reescala los frames de video para modelos builtin Real-ESRGAN.
# En AMD/DirectML el motor ONNX optimizado (grafo uint8, whole-frame, IO binding,
# pipeline de threads, PNG con OpenCV) mide ~2.1x mas rapido que NCNN (medido
# 7800XT animevideov3-x4 720p: NCNN 5.4 fps -> ONNX 11.5 fps).
# auto  = ONNX si el modelo tiene export ONNX vendored Y hay GPU EP (o device=cpu); si no, NCNN.
# ncnn  = fuerza siempre NCNN (fallback seguro, cualquier GPU Vulkan).
# onnx  = fuerza siempre el motor ONNX optimizado.
# El selector NO cambia el modelo, solo el runtime. Tambien hay override por-job desde la UI.
UPSCALE_BACKEND=auto
# Carpeta con los exports uint8-in/out de los modelos builtin (scripts/download-realesrgan-onnx.ps1).
# Vendored + gitignored, como vendor/realesrgan.
BUILTIN_ONNX_DIR=vendor/realesrgan-onnx
# Inferencia whole-frame (sin tiling) es el camino rapido; el tiling es solo un
# fallback para frames cuyo conteo de pixeles de ENTRADA supere esto (frames enormes
# / GPUs de poca VRAM). 0 desactiva el tiling (siempre whole-frame). Default ~= 3840x2160.
ONNX_WHOLE_FRAME_MAX_PIXELS=8294400
# Nivel de compresion PNG (0-9) de los frames intermedios del pipeline ONNX. Bajo = rapido;
# ffmpeg los re-encodea igual, asi que prima la velocidad (default OpenCV = 1).
ONNX_VIDEO_PNG_COMPRESSION=1
# Threads que solapan carga(N+1) y guardado(N-1) con la inferencia GPU(N). La inferencia
# GPU sigue siendo single-flight. El cuello real NO es la GPU (~68ms/frame) sino el ENCODE
# PNG del frame 4x de salida (~510ms @ 5120x2880): CPU/zlib-bound y paralelo. Por eso los
# save-threads son el lever de velocidad (medido 7900X3D: 4->5.5fps, 10->11.5fps, 14->12.6fps).
# Sin definir, ambos ESCALAN con los nucleos (save = min(12, nucleos), load = min(4, nucleos/4)).
# Definirlos aqui solo para forzar un valor fijo (p.ej. bajarlos en una CPU debil/saturada).
# ONNX_VIDEO_LOAD_THREADS=4
# ONNX_VIDEO_SAVE_THREADS=12
# Techo de RAM del pipeline ONNX: acota cuantos frames 4x de salida viven a la vez en
# la cola de guardado (deriva el maxsize del tamano real del frame; piso = save-threads).
# ONNX_VIDEO_MAX_PIPELINE_MB=1024
# Usar el export fp16 del modelo builtin en GPU cuando el archivo existe. El cuerpo de la
# red corre a resolucion de ENTRADA (domina el tiempo en cualquier escala); medido en
# 7800XT (1080p->4x): 154.9->116.5 ms/frame (1.33x), diferencia max 3/255 por pixel. En
# 720p->4x el pipeline es save-bound y no se nota; en 1080p+ el cuello es la GPU y SI se
# nota. CPU siempre usa fp32 (fp16 emulado = mas lento). False = fp32 en todos lados.
# ONNX_PREFER_FP16=True
