# Copiar este archivo a .env y ajustar segun el entorno.
# app/config.py define los defaults reales; este archivo documenta cada variable.

# --- App ---
APP_NAME=Image Upscaler AMD          # Nombre interno de la app (titulo del proceso FastAPI)
APP_HOST=127.0.0.1                   # Host de bind del servidor uvicorn
APP_PORT=8090                        # Puerto de bind del servidor uvicorn
WEB_TITLE=AMD Image Upscaler         # Titulo mostrado en la web UI

# --- Limites de subida y validacion ---
MAX_UPLOAD_MB=50                     # Tamano maximo de subida para imagenes (MB)
MAX_VIDEO_UPLOAD_MB=2048             # Tamano maximo de subida para videos (MB)
MAX_IMAGE_PIXELS=120000000           # Limite de pixeles (ancho x alto) para evitar decompression bombs

# --- GPU, concurrencia y subprocesos ---
GPU_CONCURRENCY=1                    # Jobs simultaneos en GPU (semaforo compartido imagen+video); no subir sin perfilar VRAM
CPU_FALLBACK_WORKERS=2               # Hilos de CPU para carga/guardado de frames en Real-ESRGAN NCNN (-j)
SUBPROCESS_TIMEOUT=3600              # Timeout en segundos para cualquier subproceso (engine/ffmpeg/rife) antes de matarlo

# --- FFmpeg (necesario solo para video) ---
FFMPEG_BINARY=vendor/ffmpeg/bin/ffmpeg.exe
FFPROBE_BINARY=vendor/ffmpeg/bin/ffprobe.exe
FFMPEG_DECODE_THREADS=12             # Hilos usados al extraer frames del video de entrada
FFMPEG_ENCODE_THREADS=24             # Hilos usados al re-encodear con libx264
FFMPEG_X265_THREADS=8                # Hilos usados al re-encodear con libx265 (limitado: libx265 falla en Windows con exceso de threads)

# --- Motor de upscaling (Real-ESRGAN NCNN Vulkan) ---
RUNTIME_DIR=runtime                  # Carpeta para uploads/outputs/temp/video-work (relativa a la raiz del proyecto)
ENGINE=realesrgan-ncnn               # Identificador del motor de upscaling activo
ENGINE_BINARY=vendor/realesrgan/realesrgan-ncnn-vulkan.exe
ENGINE_MODELS_DIR=vendor/realesrgan/models
DEFAULT_MODEL=realesrgan-x4plus      # Modelo preseleccionado en la web UI y en POST /api/v1/jobs
DEFAULT_SCALE=4                      # Escala preseleccionada
ALLOWED_SCALES=2,3,4                 # Escalas permitidas por la API (lista separada por comas)
DEFAULT_VIDEO_PROFILE=anime-balanced-2x  # Perfil de video preseleccionado en la web UI

# --- Retencion y limpieza automatica de runtime/outputs ---
OUTPUT_TTL_HOURS=24                  # Horas antes de borrar outputs y jobs terminados (el sweep corre cada hora)

# --- Seguridad y cola ---
# ALLOWED_ORIGINS: origenes permitidos para requests que cambian estado (POST/PUT/PATCH/DELETE).
# Si se deja sin definir, se deriva automaticamente de APP_HOST/APP_PORT
# (http://127.0.0.1:<APP_PORT> y http://localhost:<APP_PORT>, mas http://<APP_HOST>:<APP_PORT>
# si APP_HOST no es 127.0.0.1/0.0.0.0/localhost). Descomentar para fijarlo explicitamente.
# ALLOWED_ORIGINS=http://127.0.0.1:8090,http://localhost:8090
MAX_QUEUE_SIZE=20                    # Tamano maximo de cada cola de jobs (imagen y video por separado); responde 429 si se llena

# --- Interpolacion de fotogramas / FPS boost (RIFE NCNN Vulkan) ---
RIFE_BINARY=vendor/rife/rife-ncnn-vulkan.exe
RIFE_MODELS_DIR=vendor/rife/models
RIFE_MODEL=rife-v4.6                 # Modelo RIFE por defecto (recomendado, general-purpose)
ENABLE_INTERPOLATION=False           # Activa el FPS boost; requiere haber corrido scripts/download-rife.ps1
ALLOWED_FPS_MULTIPLIERS=2,3,4        # Multiplicadores de FPS permitidos por la API (lista separada por comas)

# --- Mejora de audio con IA (DeepFilterNet / RNNoise) ---
DEEPFILTER_BINARY=vendor/deepfilternet/deep-filter.exe
RNNOISE_MODEL=vendor/deepfilternet/models/sh.rnnn
ENABLE_AUDIO_ENHANCE=False           # Activa audio_enhance=deepfilter|rnnoise; requiere haber corrido scripts/download-deepfilternet.ps1
